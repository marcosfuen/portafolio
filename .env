
# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS (POSTGRES)
# ==========================================

# OPCIÓN A: Usar una URL completa (Recomendado)
# Formato: postgres://usuario:password@host:puerto/nombre_db
# Ejemplo Local: DATABASE_URL=postgres://postgres:tu_password@localhost:5432/portfolio_db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio_db

# OPCIÓN B: Parámetros individuales (El servidor los usará si DATABASE_URL falla)
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=portfolio_db
DB_PASSWORD=postgres
DB_PORT=5432

# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
PORT=3001

# API Key de Gemini (Consíguela en https://aistudio.google.com/app/apikey)
API_KEY=tu_api_key_aqui
